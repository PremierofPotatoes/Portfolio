---
import Button from "../ui/button/Button.astro";
import { projects } from "../../data/projects";
import { getIconHtml } from '../utils/IconHelper';

interface Props {
  title?: string;
}

const { title } = Astro.props as Props;
---

<section class="w-full py-10">
  <div class="mx-auto max-w-6xl px-4">
    {title && (
      <h2 class="text-3xl md:text-4xl font-semibold text-center mb-8 text-foreground">{title}</h2>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p) => {
        const iconResult = getIconHtml(p.icon);

        return (
          <article class="card-surface p-6 relative group transition-all duration-300">
            {iconResult && (
              <div 
                class:list={[
                  "absolute right-6 top-6 text-[var(--accent)] opacity-80 transition-transform duration-300 group-hover:scale-110 group-hover:opacity-100",
                  // Re-using our smart styling logic
                  iconResult.type === 'brand' 
                    ? "[&>svg]:fill-current [&>svg]:stroke-none" 
                    : "[&>svg]:stroke-current [&>svg]:fill-none [&>svg]:stroke-[2px]"
                ]}
                set:html={iconResult.html}
              />
            )}
            
            <h3 class="text-xl font-semibold text-foreground m-0 pr-10">{p.title}</h3>
            <p class="text-sm text-[color:var(--color-text-muted)] m-0">{p.techStack}</p>
            <p class="mt-3 text-[color:var(--color-text-secondary)] leading-relaxed">
              {p.description}
            </p>
            
            <div class="mt-6 flex">
              <Button href={p.ctaLink} variant="primary" size="sm">
                {p.ctaText}
              </Button>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Global selector for icons within this component */
  article :global(svg) {
    width: 24px;
    height: 24px;
  }
</style>
